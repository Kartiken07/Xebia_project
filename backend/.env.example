# Node Environment
NODE_ENV=development
PORT=5000

# MongoDB URI (Set this to your production replica set URI if using transactions)
MONGO_URI=mongodb://127.0.0.1:27017/workforceDB

# JSON Web Token Secret
JWT_SECRET=your_secure_random_string_here

# Allowed CORS Origins (Comma separated)
CORS_ORIGINS=http://localhost:5173

# Gemini API Key for AI Assistant (Optional)
# GEMINI_API_KEY=your_gemini_api_key
